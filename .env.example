PORT=8080
ADMIN_USER=admin
ADMIN_PASS=change-this-password
ADMIN_EMAIL=admin@example.com
MASTER_TOKEN=change-this-to-a-long-random-secret

# The address phones should open after scanning the master QR.
# Same Wi-Fi example:
# PUBLIC_BASE_URL=http://192.168.100.6:8080
# Public hosting/ngrok example:
# PUBLIC_BASE_URL=https://your-public-domain.com

# Optional HTTPS for production/local secure testing:
# HTTPS_KEY=C:\path\to\privkey.pem
# HTTPS_CERT=C:\path\to\fullchain.pem

# Supabase migration target:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional password reset email, using https://resend.com:
# RESEND_API_KEY=re_your_key
# RESET_FROM_EMAIL=MAPPHEX ID Cards <onboarding@resend.dev>
# Local-only recovery fallback when no email provider is configured:
# SHOW_RESET_CODE_WHEN_EMAIL_DISABLED=true
